# Python
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Virtualenv
.venv/
venv/

# macOS
.DS_Store

# Output artifacts (user-generated, never commit these specific filenames)
analysis-data.json
samples.json
peer-review.md
peer-review-hr.md
cc-user-autopsy.html
cc-user-autopsy-hr.html
*.skill

# User-specific HR-mode setup (profile, allowlist, artifacts). These live in
# ~/.claude/ and should never be in this repo — listed here in case someone
# copies them in by accident.
cc-autopsy-profile.json
cc-autopsy-public-projects.json
cc-autopsy-artifacts.json

# But DO commit the canned example reports (synthetic data)
!assets/example-output.html
!assets/example-output-hr.html

# Skill eval workspace (transient)
cc-user-autopsy-workspace/

# Anything under evals/results/
evals/results/
evals/iteration-*/

# Never commit anyone's personal usage data
session-meta/
facets/
usage-data/

# Defensive: credentials / secrets patterns. Nothing currently matches these,
# but the rules guard against accidental commits of ad-hoc credential files.
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
secrets.json
auth.json
